{
  "name": "catalog-pep",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:sema-image": "node --env-file=.env scripts/generate-sema-image.mjs",
    "generate:product-images": "node --env-file=.env scripts/generate-all-product-images-v2.mjs",
    "verify:product-images": "node scripts/verify-product-images.mjs",
    "generate:image-manifest": "node scripts/generate-image-manifest.mjs",
    "generate:lifestyle-images": "node --env-file=.env scripts/generate-lifestyle-images.mjs",
    "generate:og-image": "node --env-file=.env scripts/generate-og-image.mjs",
    "generate:og-images": "node --env-file=.env scripts/generate-og-images.mjs",
    "generate:rfk-image": "node --env-file=.env scripts/generate-rfk-article-image.mjs",
    "generate:blur-placeholders": "node scripts/generate-blur-placeholders.mjs",
    "download:pdfs": "node scripts/download-pdfs.mjs",
    "extract:pdfs": "node scripts/extract-pdf-content.mjs",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "mcp:install": "cd mcp-server && npm install",
    "mcp:start": "cd mcp-server && npm start",
    "mcp:dev": "cd mcp-server && npm run dev"
  },
  "dependencies": {
    "@fal-ai/client": "^1.9.1",
    "@sendgrid/mail": "^8.1.6",
    "@supabase/supabase-js": "^2.98.0",
