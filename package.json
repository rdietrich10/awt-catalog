    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.563.0",
    "next": "14.2.18",
    "potrace": "^2.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "jsdom": "^29.0.2",
    "pdf-parse": "^2.4.5",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5",
    "vercel": "^39.0.0",
    "vitest": "^4.1.3"
