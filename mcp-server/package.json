{
  "name": "awt-catalog-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for AW Therapeutics peptide catalog",
  "scripts": {
    "start": "tsx --tsconfig tsconfig.json src/index.ts",
    "dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start:built": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  },
  "bin": {
    "awt-catalog-mcp": "dist/index.js"
  }
}
